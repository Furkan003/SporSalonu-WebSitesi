@{
    ViewData["Title"] = "Erişim Engellendi";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NFA Spor Salonu</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/custom-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <div class="nfa-auth-wrapper">
        <div class="card nfa-auth-card card-nfa-shadow-lg nfa-animate-in text-center" style="max-width:460px;">
            <div class="nfa-auth-body py-5">
                <div class="mb-4">
                    <span style="display:inline-flex;align-items:center;justify-content:center;width:72px;height:72px;border-radius:50%;background:oklch(0.6271 0.1936 33.339 / .12);">
                        <i class="bi bi-shield-lock-fill" style="font-size:2rem;color:var(--nfa-destructive);"></i>
                    </span>
                </div>
                <h2 class="fw-bold mb-2" style="font-size:1.5rem;">Erişim Engellendi</h2>
                <p class="text-nfa-muted mb-4" style="font-size:.9375rem;">
                    Bu sayfaya erişim yetkiniz bulunmamaktadır.<br />
                    Lütfen yönetici ile iletişime geçin.
                </p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-nfa-primary px-4">
                    <i class="bi bi-house me-2"></i>Ana Sayfaya Dön
                </a>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
