@model LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NFA Spor Salonu</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/custom-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <div class="nfa-auth-wrapper">
        <div class="card nfa-auth-card card-nfa-shadow-lg nfa-animate-in">

            @* ── Header ── *@
            <div class="nfa-auth-header">
                <div class="nfa-auth-brand">NFA</div>
                <h1>Hoş Geldiniz</h1>
                <p>Hesabınıza giriş yapın</p>
            </div>

            @* ── Body ── *@
            <div class="nfa-auth-body">

                @* ── TempData Alerts ── *@
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-nfa alert-nfa-success d-flex align-items-center alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        <span>@TempData["Success"]</span>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-nfa alert-nfa-error d-flex align-items-center alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <span>@TempData["Error"]</span>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
                    </div>
                }

                @* ── Validation Summary ── *@
                <div asp-validation-summary="All" class="text-danger mb-3" style="font-size:.875rem;"></div>

                @* ── Login Form ── *@
                <form asp-controller="Account" asp-action="Login" method="post">
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                    @* E-posta *@
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold" style="font-size:.875rem;"></label>
                        <div class="input-group">
                            <span class="input-group-text border-end-0" style="background:var(--nfa-card);border-color:var(--nfa-input);border-radius:var(--nfa-radius) 0 0 var(--nfa-radius);">
                                <i class="bi bi-envelope text-nfa-muted"></i>
                            </span>
                            <input asp-for="Email" class="form-control form-control-nfa border-start-0"
                                   placeholder="ornek@email.com"
                                   style="border-radius:0 var(--nfa-radius) var(--nfa-radius) 0;" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger" style="font-size:.8125rem;"></span>
                    </div>

                    @* Şifre *@
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold" style="font-size:.875rem;"></label>
                        <div class="input-group">
                            <span class="input-group-text border-end-0" style="background:var(--nfa-card);border-color:var(--nfa-input);border-radius:var(--nfa-radius) 0 0 var(--nfa-radius);">
                                <i class="bi bi-lock text-nfa-muted"></i>
                            </span>
                            <input asp-for="Password" class="form-control form-control-nfa border-start-0"
                                   placeholder="••••••••"
                                   style="border-radius:0 var(--nfa-radius) var(--nfa-radius) 0;" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger" style="font-size:.8125rem;"></span>
                    </div>

                    @* Beni Hatırla *@
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label" style="font-size:.875rem;"></label>
                        </div>
                    </div>

                    @* Giriş Butonu *@
                    <button type="submit" class="btn btn-nfa-primary w-100 py-2">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
                    </button>
                </form>

                @* ── Kayıt Linki ── *@
                <div class="text-center mt-4 pt-3" style="border-top:1px solid var(--nfa-border);">
                    <span class="text-nfa-muted" style="font-size:.875rem;">Hesabınız yok mu?</span>
                    <a asp-controller="Account" asp-action="Register" class="nfa-link ms-1" style="font-size:.875rem;">
                        Kayıt Olun
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
