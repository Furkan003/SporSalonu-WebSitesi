@model MembershipPackagesViewModel
@{
    ViewData["Title"] = "Üyelik Paketleri";
    Layout = "_Layout";
}

<section style="padding-top:100px;padding-bottom:60px;background:linear-gradient(135deg, var(--nfa-bg) 0%, var(--nfa-muted) 100%);min-height:100vh;">
    <div class="container">

        @* ── Başlık ── *@
        <div class="text-center mb-5 nfa-animate-in">
            <h1 class="fw-bold" style="font-size:2rem;">
                <i class="bi bi-gem me-2" style="color:var(--nfa-primary);"></i>Üyelik Paketleri
            </h1>
            <p class="text-nfa-muted" style="max-width:520px;margin:0 auto;">
                Size en uygun paketi seçin ve spor yolculuğunuza bugün başlayın.
            </p>
        </div>

        @* ── Mevcut Üyelik Bilgisi ── *@
        @if (Model.CurrentPlanName != null)
        {
            <div class="alert alert-nfa alert-nfa-success d-flex align-items-center mb-4 nfa-animate-in" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>
                <span>Aktif paketiniz: <strong>@Model.CurrentPlanName</strong> — Bitiş: @Model.MembershipEndDate?.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))</span>
            </div>
        }

        @* ── Paket Kartları ── *@
        <div class="row g-4 justify-content-center">
            @foreach (var plan in Model.Plans)
            {
                var isPopular = plan.ActiveMemberCount >= Model.Plans.Max(p => p.ActiveMemberCount) && plan.ActiveMemberCount > 0;
                <div class="col-md-6 col-lg-4">
                    <div class="card card-nfa-shadow-lg h-100 nfa-animate-in position-relative" style="border-radius:calc(var(--nfa-radius) * 2);overflow:hidden;@(isPopular ? "border:2px solid var(--nfa-primary);" : "")">

                        @if (isPopular)
                        {
                            <div class="text-center py-1" style="background:var(--nfa-primary);color:var(--nfa-primary-fg);font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;">
                                <i class="bi bi-star-fill me-1"></i>En Popüler
                            </div>
                        }

                        <div class="card-body d-flex flex-column p-4">
                            @* Paket Adı *@
                            <h5 class="fw-bold text-center mb-1">@plan.PlanName</h5>
                            <p class="text-nfa-muted text-center mb-3" style="font-size:.8125rem;">
                                @(plan.DurationInDays) gün
                            </p>

                            @* Fiyat *@
                            <div class="text-center mb-4">
                                <span style="font-size:2.5rem;font-weight:800;color:var(--nfa-primary);">
                                    @plan.Price.ToString("N0", new System.Globalization.CultureInfo("tr-TR"))
                                </span>
                                <span class="text-nfa-muted" style="font-size:1rem;">₺</span>
                            </div>

                            @* Açıklama *@
                            @if (!string.IsNullOrEmpty(plan.Description))
                            {
                                <p class="text-nfa-muted text-center mb-4" style="font-size:.875rem;line-height:1.6;">
                                    @plan.Description
                                </p>
                            }

                            @* Özellikler *@
                            <ul class="list-unstyled mb-4 flex-grow-1">
                                <li class="d-flex align-items-center gap-2 mb-2" style="font-size:.875rem;">
                                    <i class="bi bi-check-circle-fill" style="color:oklch(0.72 0.19 155);"></i>
                                    @plan.DurationInDays gün sınırsız erişim
                                </li>
                                <li class="d-flex align-items-center gap-2 mb-2" style="font-size:.875rem;">
                                    <i class="bi bi-check-circle-fill" style="color:oklch(0.72 0.19 155);"></i>
                                    Profesyonel ekipman kullanımı
                                </li>
                                <li class="d-flex align-items-center gap-2 mb-2" style="font-size:.875rem;">
                                    <i class="bi bi-check-circle-fill" style="color:oklch(0.72 0.19 155);"></i>
                                    Kişisel ölçüm takibi
                                </li>
                                @if (plan.DurationInDays >= 90)
                                {
                                    <li class="d-flex align-items-center gap-2 mb-2" style="font-size:.875rem;">
                                        <i class="bi bi-check-circle-fill" style="color:oklch(0.72 0.19 155);"></i>
                                        Kişisel antrenör desteği
                                    </li>
                                }
                            </ul>

                            @* Satın Al Butonu *@
                            <a asp-controller="Membership" asp-action="Purchase" asp-route-planId="@plan.PlanId"
                               class="btn @(isPopular ? "btn-nfa-primary" : "btn-nfa-outline") w-100 py-2">
                                <i class="bi bi-bag-plus me-1"></i>Satın Al
                            </a>

                            @* Aktif Üye Sayısı *@
                            <div class="text-center mt-3">
                                <small class="text-nfa-muted">
                                    <i class="bi bi-people me-1"></i>@plan.ActiveMemberCount aktif üye
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.Plans.Any())
        {
            <div class="text-center py-5 nfa-animate-in">
                <i class="bi bi-inbox" style="font-size:3rem;color:var(--nfa-muted-fg);"></i>
                <p class="text-nfa-muted mt-3">Henüz aktif üyelik paketi bulunmuyor.</p>
            </div>
        }

    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/custom-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}
