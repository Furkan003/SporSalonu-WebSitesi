@model ProgramDetailViewModel
@{
    ViewData["Title"] = Model.Title;
    Layout = "_Layout";
}

<section style="padding-top:100px;padding-bottom:60px;min-height:100vh;">
    <div class="container" style="max-width:800px;">
        <div class="card card-nfa-shadow-lg nfa-animate-in" style="border-radius:calc(var(--nfa-radius) * 2);overflow:hidden;">
            <div style="background:linear-gradient(135deg, var(--nfa-secondary) 0%, oklch(0.4 0.02 286) 100%);padding:2rem;color:#fff;">
                <div class="d-flex align-items-center gap-3">
                    @if (Model.ProgramType == "Workout")
                    {
                        <div style="width:50px;height:50px;border-radius:12px;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:1.5rem;">
                            <i class="bi bi-lightning-fill"></i>
                        </div>
                    }
                    else
                    {
                        <div style="width:50px;height:50px;border-radius:12px;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:1.5rem;">
                            <i class="bi bi-heart-pulse-fill"></i>
                        </div>
                    }
                    <div>
                        <h3 class="fw-bold mb-0">@Model.Title</h3>
                        <span style="opacity:.7;font-size:.875rem;">@Model.ProgramType Programı</span>
                    </div>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="row g-3 mb-4">
                    <div class="col-sm-4">
                        <div class="text-nfa-muted" style="font-size:.75rem;">Eğitmen</div>
                        <div class="fw-semibold">@(Model.TrainerName ?? "–")</div>
                    </div>
                    <div class="col-sm-4">
                        <div class="text-nfa-muted" style="font-size:.75rem;">Oluşturulma</div>
                        <div class="fw-semibold">@(Model.CreatedDate?.ToString("dd.MM.yyyy") ?? "–")</div>
                    </div>
                    <div class="col-sm-4">
                        <div class="text-nfa-muted" style="font-size:.75rem;">Bitiş</div>
                        <div class="fw-semibold">@(Model.EndDate?.ToString("dd.MM.yyyy") ?? "Süresiz")</div>
                    </div>
                </div>
                <h6 class="nfa-section-title">Program İçeriği</h6>
                <div class="p-3" style="background:var(--nfa-muted);border-radius:var(--nfa-radius);white-space:pre-wrap;font-size:.875rem;line-height:1.8;">@Model.Content</div>
                <div class="mt-4">
                    <a asp-action="Programs" class="btn btn-nfa-outline"><i class="bi bi-arrow-left me-1"></i>Programlarıma Dön</a>
                </div>
            </div>
        </div>
    </div>
</section>
@section Styles {
    <link rel="stylesheet" href="~/css/custom-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}
