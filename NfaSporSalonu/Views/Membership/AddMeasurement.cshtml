@model AddMeasurementViewModel
@{
    ViewData["Title"] = "Ölçüm Ekle";
    Layout = "_Layout";
}

<section style="padding-top:100px;padding-bottom:60px;min-height:100vh;">
    <div class="container" style="max-width:600px;">
        <div class="card card-nfa-shadow-lg nfa-animate-in" style="border-radius:calc(var(--nfa-radius) * 2);overflow:hidden;">
            <div style="background:linear-gradient(135deg, var(--nfa-secondary) 0%, oklch(0.4 0.02 286) 100%);padding:2rem;color:#fff;text-align:center;">
                <i class="bi bi-rulers" style="font-size:2.5rem;opacity:.9;"></i>
                <h2 class="fw-bold mt-2 mb-1">Yeni Ölçüm Ekle</h2>
                <p style="opacity:.8;font-size:.875rem;margin-bottom:0;">Gelişiminizi takip etmek için ölçümlerinizi girin</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="AddMeasurement" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-6">
                            <label asp-for="Height" class="form-label fw-semibold" style="font-size:.875rem;">Boy (cm)</label>
                            <input asp-for="Height" class="form-control form-control-nfa" placeholder="175" />
                            <span asp-validation-for="Height" class="text-danger" style="font-size:.75rem;"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="Weight" class="form-label fw-semibold" style="font-size:.875rem;">Kilo (kg)</label>
                            <input asp-for="Weight" class="form-control form-control-nfa" placeholder="75" />
                            <span asp-validation-for="Weight" class="text-danger" style="font-size:.75rem;"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="Bicep" class="form-label fw-semibold" style="font-size:.875rem;">Bicep (cm)</label>
                            <input asp-for="Bicep" class="form-control form-control-nfa" placeholder="35" />
                            <span asp-validation-for="Bicep" class="text-danger" style="font-size:.75rem;"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="Chest" class="form-label fw-semibold" style="font-size:.875rem;">Göğüs (cm)</label>
                            <input asp-for="Chest" class="form-control form-control-nfa" placeholder="95" />
                            <span asp-validation-for="Chest" class="text-danger" style="font-size:.75rem;"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="Waist" class="form-label fw-semibold" style="font-size:.875rem;">Bel (cm)</label>
                            <input asp-for="Waist" class="form-control form-control-nfa" placeholder="80" />
                            <span asp-validation-for="Waist" class="text-danger" style="font-size:.75rem;"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Notes" class="form-label fw-semibold" style="font-size:.875rem;">Notlar</label>
                            <textarea asp-for="Notes" class="form-control form-control-nfa" rows="2" placeholder="İsteğe bağlı notlar..."></textarea>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-nfa-primary w-100 py-2 mt-4"><i class="bi bi-check-lg me-1"></i>Ölçümü Kaydet</button>
                </form>
                <div class="text-center mt-3">
                    <a asp-action="Measurements" class="nfa-link" style="font-size:.8125rem;"><i class="bi bi-arrow-left me-1"></i>Ölçümlerime Dön</a>
                </div>
            </div>
        </div>
    </div>
</section>
@section Styles {
    <link rel="stylesheet" href="~/css/custom-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
