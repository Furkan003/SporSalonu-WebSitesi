@model MemberNotificationListViewModel
@{
    ViewData["Title"] = "Bildirimlerim";
    Layout = "_Layout";
}

<section style="padding-top:100px;padding-bottom:60px;min-height:100vh;">
    <div class="container" style="max-width:800px;">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 nfa-animate-in">
            <div>
                <h1 class="fw-bold mb-1" style="font-size:1.75rem;"><i class="bi bi-bell me-2" style="color:var(--nfa-primary);"></i>Bildirimlerim
                    @if (Model.UnreadCount > 0){<span class="badge badge-nfa-pending rounded-pill ms-2">@Model.UnreadCount</span>}
                </h1>
            </div>
            @if (Model.UnreadCount > 0)
            {
                <form asp-action="MarkAllAsRead" method="post" class="mt-3 mt-md-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-nfa-outline btn-sm"><i class="bi bi-check-all me-1"></i>Tümünü Okundu İşaretle</button>
                </form>
            }
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-nfa alert-nfa-success d-flex align-items-center alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i><span>@TempData["Success"]</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card card-nfa-shadow nfa-animate-in">
            <div class="card-body p-0">
                @if (Model.Notifications.Any())
                {
                    @foreach (var n in Model.Notifications)
                    {
                        <div class="nfa-notification-item @(n.IsRead ? "" : "unread")">
                            @if (!n.IsRead)
                            {
                                <div class="nfa-notif-dot"></div>
                            }
                            else
                            {
                                <div style="width:8px;flex-shrink:0;"></div>
                            }
                            <div class="flex-grow-1">
                                <div style="font-size:.875rem;" class="@(n.IsRead ? "text-nfa-muted" : "fw-semibold")">@n.Message</div>
                                <div class="text-nfa-muted" style="font-size:.75rem;">
                                    <i class="bi bi-clock me-1"></i>@(n.CreatedDate?.ToString("dd MMM yyyy HH:mm") ?? "–")
                                    @if (!string.IsNullOrEmpty(n.NotificationType))
                                    {
                                        <span class="ms-2 badge bg-nfa-muted rounded-pill" style="font-size:.6875rem;">@n.NotificationType</span>
                                    }
                                </div>
                            </div>
                            @if (!n.IsRead)
                            {
                                <form asp-action="MarkAsRead" asp-route-id="@n.NotificationId" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-nfa-outline btn-sm px-2 py-1" title="Okundu"><i class="bi bi-check2"></i></button>
                                </form>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-bell-slash" style="font-size:3rem;color:var(--nfa-muted-fg);"></i>
                        <p class="text-nfa-muted mt-3">Bildiriminiz bulunmuyor.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
@section Styles {
    <link rel="stylesheet" href="~/css/custom-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}
