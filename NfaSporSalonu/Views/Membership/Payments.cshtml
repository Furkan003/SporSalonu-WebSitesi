@model PaymentListViewModel
@{
    ViewData["Title"] = "Ödeme Geçmişi";
    Layout = "_Layout";
}

<section style="padding-top:100px;padding-bottom:60px;min-height:100vh;">
    <div class="container">

        @* Başlık *@
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 nfa-animate-in">
            <div>
                <h1 class="fw-bold mb-1" style="font-size:1.75rem;">
                    <i class="bi bi-receipt me-2" style="color:var(--nfa-primary);"></i>Ödeme Geçmişi
                </h1>
                <p class="text-nfa-muted mb-0">Tüm ödeme işlemlerinizi buradan takip edebilirsiniz.</p>
            </div>
            <div class="mt-3 mt-md-0">
                <div class="card card-nfa-shadow p-3" style="border-radius:var(--nfa-radius);">
                    <span class="text-nfa-muted" style="font-size:.75rem;">Toplam Ödenen</span>
                    <span class="fw-bold" style="font-size:1.25rem;color:var(--nfa-primary);">
                        @Model.TotalPaid.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))
                    </span>
                </div>
            </div>
        </div>

        @* TempData *@
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-nfa alert-nfa-success d-flex align-items-center alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i><span>@TempData["Success"]</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @* Tablo *@
        <div class="card card-nfa-shadow nfa-animate-in">
            <div class="card-body p-0">
                @if (Model.Payments.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-nfa mb-0">
                            <thead>
                                <tr>
                                    <th>İşlem No</th>
                                    <th>Paket</th>
                                    <th>Tutar</th>
                                    <th>Yöntem</th>
                                    <th>Tarih</th>
                                    <th>Durum</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.Payments)
                                {
                                    <tr>
                                        <td class="fw-semibold" style="font-family:monospace;font-size:.8125rem;">@(p.TransactionId ?? "–")</td>
                                        <td>@(p.PlanName ?? "–")</td>
                                        <td class="fw-bold">@p.Amount.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</td>
                                        <td><i class="bi bi-credit-card me-1"></i>@(p.PaymentMethod ?? "–")</td>
                                        <td>@(p.PaymentDate?.ToString("dd.MM.yyyy") ?? "–")</td>
                                        <td>
                                            @if (p.Status == "Completed")
                                            {
                                                <span class="badge badge-nfa-active rounded-pill px-2 py-1">Tamamlandı</span>
                                            }
                                            else if (p.Status == "Pending")
                                            {
                                                <span class="badge badge-nfa-pending rounded-pill px-2 py-1">Bekliyor</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-nfa-expired rounded-pill px-2 py-1">@p.Status</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-action="PaymentDetail" asp-route-id="@p.PaymentId" class="btn btn-nfa-outline btn-sm px-2 py-1">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-receipt" style="font-size:3rem;color:var(--nfa-muted-fg);"></i>
                        <p class="text-nfa-muted mt-3">Henüz ödeme kaydınız bulunmuyor.</p>
                        <a asp-action="Packages" class="btn btn-nfa-primary btn-sm px-4">
                            <i class="bi bi-bag-plus me-1"></i>Paket Satın Al
                        </a>
                    </div>
                }
            </div>
        </div>

    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/custom-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}
