@model MeasurementListViewModel
@{
    ViewData["Title"] = "Ölçümlerim";
    Layout = "_Layout";
}

<section style="padding-top:100px;padding-bottom:60px;min-height:100vh;">
    <div class="container">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 nfa-animate-in">
            <div>
                <h1 class="fw-bold mb-1" style="font-size:1.75rem;"><i class="bi bi-rulers me-2" style="color:var(--nfa-primary);"></i>Ölçümlerim</h1>
                <p class="text-nfa-muted mb-0">Vücut ölçümlerinizi takip edin.</p>
            </div>
            <a asp-action="AddMeasurement" class="btn btn-nfa-primary mt-3 mt-md-0"><i class="bi bi-plus-lg me-1"></i>Yeni Ölçüm Ekle</a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-nfa alert-nfa-success d-flex align-items-center alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i><span>@TempData["Success"]</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card card-nfa-shadow nfa-animate-in">
            <div class="card-body p-0">
                @if (Model.Measurements.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-nfa mb-0">
                            <thead>
                                <tr>
                                    <th>Tarih</th>
                                    <th>Boy (cm)</th>
                                    <th>Kilo (kg)</th>
                                    <th>Bicep (cm)</th>
                                    <th>Göğüs (cm)</th>
                                    <th>Bel (cm)</th>
                                    <th>Not</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in Model.Measurements)
                                {
                                    <tr>
                                        <td class="fw-semibold">@(m.MeasurementDate?.ToString("dd.MM.yyyy") ?? "–")</td>
                                        <td>@(m.Height?.ToString("0.#") ?? "–")</td>
                                        <td>@(m.Weight?.ToString("0.#") ?? "–")</td>
                                        <td>@(m.Bicep?.ToString("0.#") ?? "–")</td>
                                        <td>@(m.Chest?.ToString("0.#") ?? "–")</td>
                                        <td>@(m.Waist?.ToString("0.#") ?? "–")</td>
                                        <td class="text-nfa-muted" style="font-size:.8125rem;max-width:150px;overflow:hidden;text-overflow:ellipsis;">@(m.Notes ?? "–")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-rulers" style="font-size:3rem;color:var(--nfa-muted-fg);"></i>
                        <p class="text-nfa-muted mt-3">Henüz ölçüm kaydınız bulunmuyor.</p>
                        <a asp-action="AddMeasurement" class="btn btn-nfa-primary btn-sm px-4"><i class="bi bi-plus-lg me-1"></i>İlk Ölçümünüzü Ekleyin</a>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
@section Styles {
    <link rel="stylesheet" href="~/css/custom-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}
