@model PaymentDetailViewModel
@{
    ViewData["Title"] = "Fatura Detayı";
    Layout = "_Layout";
}

<section style="padding-top:100px;padding-bottom:60px;min-height:100vh;">
    <div class="container" style="max-width:700px;">
        <div class="card card-nfa-shadow-lg nfa-animate-in" style="border-radius:calc(var(--nfa-radius) * 2);overflow:hidden;">
            <div style="background:linear-gradient(135deg, var(--nfa-secondary) 0%, oklch(0.4 0.02 286) 100%);padding:2rem;color:#fff;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="fw-bold mb-1">NFA Spor Merkezi</h4>
                        <p style="opacity:.7;font-size:.8125rem;margin-bottom:0;">Fatura / Ödeme Makbuzu</p>
                    </div>
                    <div class="text-end">
                        <div style="font-size:.8125rem;opacity:.7;">İşlem No</div>
                        <div class="fw-bold" style="font-family:monospace;">@(Model.TransactionId ?? "–")</div>
                    </div>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    @if (Model.Status == "Completed")
                    {
                        <span class="badge badge-nfa-active rounded-pill px-4 py-2" style="font-size:.9rem;"><i class="bi bi-check-circle-fill me-1"></i>Tamamlandı</span>
                    }
                    else
                    {
                        <span class="badge badge-nfa-pending rounded-pill px-4 py-2" style="font-size:.9rem;">@Model.Status</span>
                    }
                </div>
                <div class="row mb-4">
                    <div class="col-sm-6">
                        <h6 class="nfa-section-title">Üye Bilgileri</h6>
                        <div style="font-size:.875rem;">
                            <div class="fw-semibold">@(Model.MemberFullName ?? "–")</div>
                            <div class="text-nfa-muted">@(Model.MemberEmail ?? "–")</div>
                        </div>
                    </div>
                    <div class="col-sm-6 mt-3 mt-sm-0">
                        <h6 class="nfa-section-title">Ödeme Bilgileri</h6>
                        <div style="font-size:.875rem;">
                            <div><span class="text-nfa-muted">Yöntem:</span> @(Model.PaymentMethod ?? "–")</div>
                            <div><span class="text-nfa-muted">Tarih:</span> @(Model.PaymentDate?.ToString("dd.MM.yyyy HH:mm") ?? "–")</div>
                        </div>
                    </div>
                </div>
                <div class="p-3 mb-4" style="background:var(--nfa-muted);border-radius:var(--nfa-radius);">
                    <div class="d-flex justify-content-between mb-2" style="font-size:.875rem;"><span>Paket</span><span class="fw-semibold">@(Model.PlanName ?? "–")</span></div>
                    @if (Model.PlanDuration != null){<div class="d-flex justify-content-between mb-2" style="font-size:.875rem;"><span>Süre</span><span>@Model.PlanDuration gün</span></div>}
                    @if (Model.MembershipStartDate != null){<div class="d-flex justify-content-between mb-2" style="font-size:.875rem;"><span>Başlangıç</span><span>@Model.MembershipStartDate?.ToString("dd.MM.yyyy")</span></div>}
                    @if (Model.MembershipEndDate != null){<div class="d-flex justify-content-between" style="font-size:.875rem;"><span>Bitiş</span><span>@Model.MembershipEndDate?.ToString("dd.MM.yyyy")</span></div>}
                </div>
                <div class="d-flex justify-content-between align-items-center p-3" style="border-top:2px solid var(--nfa-border);">
                    <span class="fw-bold" style="font-size:1.125rem;">Toplam</span>
                    <span class="fw-bold" style="font-size:1.5rem;color:var(--nfa-primary);">@Model.Amount.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</span>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <a asp-action="Payments" class="btn btn-nfa-outline flex-grow-1"><i class="bi bi-arrow-left me-1"></i>Geri</a>
                    <button onclick="window.print()" class="btn btn-nfa-secondary flex-grow-1"><i class="bi bi-printer me-1"></i>Yazdır</button>
                </div>
            </div>
        </div>
    </div>
</section>
@section Styles {
    <link rel="stylesheet" href="~/css/custom-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}
