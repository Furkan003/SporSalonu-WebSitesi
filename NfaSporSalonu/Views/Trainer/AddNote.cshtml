@model AddTrainerNoteViewModel
@{
    ViewData["Title"] = "Eğitmen Notu Ekle";
    Layout = "_Layout";
}

<div class="container" style="padding-top:7rem;padding-bottom:3rem;max-width:720px;">

    @* TempData Alerts *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-nfa alert-nfa-success d-flex align-items-center alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <span>@TempData["Success"]</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-nfa alert-nfa-error d-flex align-items-center alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <span>@TempData["Error"]</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <div class="card card-nfa-shadow-lg nfa-animate-in" style="border-radius:calc(var(--nfa-radius) * 2);">
        @* Header *@
        <div style="padding:1.5rem 2rem 1rem;border-bottom:1px solid oklch(0.5 0 0 / .08);">
            <h5 class="fw-bold mb-1">
                <i class="bi bi-journal-plus me-2" style="color:var(--nfa-primary);"></i>Eğitmen Notu Ekle
            </h5>
            <p class="text-nfa-muted mb-0" style="font-size:.8125rem;">
                Seçilen antrenörün öğrencisine not ekleyebilirsiniz.
            </p>
        </div>

        <div class="card-body" style="padding:1.5rem 2rem;">
            @* Validation Summary *@
            <div asp-validation-summary="All" class="text-danger mb-3" style="font-size:.875rem;"></div>

            <form asp-controller="Trainer" asp-action="AddNote" method="post">
                @Html.AntiForgeryToken()

                @* Antrenör Seçimi *@
                <div class="mb-3">
                    <label asp-for="TrainerId" class="form-label fw-semibold" style="font-size:.875rem;">
                        <i class="bi bi-person-badge me-1" style="color:var(--nfa-primary);"></i>Antrenör
                    </label>
                    <select asp-for="TrainerId" class="form-select" style="border-radius:var(--nfa-radius);font-size:.875rem;">
                        <option value="">— Antrenör Seçiniz —</option>
                        @foreach (var trainer in Model.AvailableTrainers)
                        {
                            <option value="@trainer.UserId">@trainer.FullName (@trainer.Email)</option>
                        }
                    </select>
                    <span asp-validation-for="TrainerId" class="text-danger" style="font-size:.8125rem;"></span>
                </div>

                @* Üye Seçimi *@
                <div class="mb-3">
                    <label asp-for="TraineeId" class="form-label fw-semibold" style="font-size:.875rem;">
                        <i class="bi bi-person me-1" style="color:var(--nfa-primary);"></i>Üye
                    </label>
                    <select asp-for="TraineeId" class="form-select" style="border-radius:var(--nfa-radius);font-size:.875rem;">
                        <option value="">— Üye Seçiniz —</option>
                        @foreach (var trainee in Model.AvailableTrainees)
                        {
                            <option value="@trainee.UserId">@trainee.FullName (@trainee.Email)</option>
                        }
                    </select>
                    <span asp-validation-for="TraineeId" class="text-danger" style="font-size:.8125rem;"></span>
                </div>

                @* Not İçeriği *@
                <div class="mb-4">
                    <label asp-for="NoteContent" class="form-label fw-semibold" style="font-size:.875rem;">
                        <i class="bi bi-chat-left-text me-1" style="color:var(--nfa-primary);"></i>Not İçeriği
                    </label>
                    <textarea asp-for="NoteContent" class="form-control" rows="5"
                              placeholder="Eğitmen notunu buraya yazınız..."
                              style="border-radius:var(--nfa-radius);font-size:.875rem;resize:vertical;"></textarea>
                    <span asp-validation-for="NoteContent" class="text-danger" style="font-size:.8125rem;"></span>
                    <div class="text-nfa-muted mt-1" style="font-size:.75rem;">Maksimum 1000 karakter.</div>
                </div>

                @* Butonlar *@
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-nfa-primary px-4">
                        <i class="bi bi-check-lg me-1"></i>Notu Kaydet
                    </button>
                    <a asp-controller="Trainer" asp-action="Index" class="btn btn-nfa-outline px-4">
                        <i class="bi bi-arrow-left me-1"></i>Geri Dön
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
