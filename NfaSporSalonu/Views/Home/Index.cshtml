@{
    ViewData["Title"] = "Ana Sayfa";
}

@section Styles {
    <style>
        /* ─── Landing Page Styles ─── */

        /* Hero — Background Image Layer */
        .nfa-hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
            background: #0d0d12; /* fallback */
        }

        /* BG image — zoomed & fixed */
        .nfa-hero-bg {
            position: absolute;
            inset: 0;
            background: url('/images/1a.jpg') center center / cover no-repeat;
            transform: scale(1.08);
            filter: brightness(.35) saturate(1.1);
            transition: transform 18s ease-out;
            z-index: 0;
        }
        .nfa-hero:hover .nfa-hero-bg { transform: scale(1.12); }

        /* Dark cinematic overlay */
        .nfa-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                linear-gradient(180deg,
                    rgba(10,10,18,.75) 0%,
                    rgba(10,10,18,.5) 40%,
                    rgba(10,10,18,.7) 70%,
                    rgba(10,10,18,.92) 100%),
                radial-gradient(ellipse 55% 45% at 25% 60%, oklch(0.8606 0.1731 91.9357 / .06) 0%, transparent 70%),
                radial-gradient(ellipse 40% 50% at 75% 40%, oklch(0.62 0.18 250 / .04) 0%, transparent 60%);
            z-index: 1;
            pointer-events: none;
        }

        /* Bottom fade to page bg */
        .nfa-hero::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 150px;
            background: linear-gradient(to top, var(--nfa-bg), transparent);
            z-index: 2;
            pointer-events: none;
        }

        /* ─── Hero Typography ─── */
        .nfa-hero-title {
            font-size: clamp(2.25rem, 5vw, 3.75rem);
            font-weight: 800;
            line-height: 1.1;
            letter-spacing: -.02em;
            color: #fff;
            text-shadow: 0 2px 30px rgba(0,0,0,.4);
        }
        .nfa-hero-title .nfa-gold {
            background: linear-gradient(135deg, var(--nfa-primary), oklch(0.92 0.065 74));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .nfa-hero-sub {
            font-size: clamp(.95rem, 1.5vw, 1.15rem);
            color: rgba(255,255,255,.72);
            max-width: 540px;
            line-height: 1.7;
            text-shadow: 0 1px 12px rgba(0,0,0,.3);
        }
        .nfa-hero-stats { display: flex; gap: 2.5rem; margin-top: 2.5rem; }
        .nfa-hero-stats .hs-val { font-size: 1.75rem; font-weight: 800; color: var(--nfa-primary); text-shadow: 0 0 20px oklch(0.8606 0.1731 91.9357 / .3); }
        .nfa-hero-stats .hs-lbl { font-size: .75rem; color: rgba(255,255,255,.5); text-transform: uppercase; letter-spacing: .06em; }

        /* ─── Trophy Orb (Right Side) ─── */
        .nfa-trophy-orb {
            position: relative;
            width: 360px;
            height: 360px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Concentric ripple rings */
        .nfa-trophy-ring {
            position: absolute;
            border-radius: 50%;
            border: 1px solid oklch(0.8606 0.1731 91.9357 / .12);
            pointer-events: none;
        }
        .nfa-trophy-ring--1 {
            width: 100%; height: 100%;
            animation: trophyPulse 4s ease-in-out infinite;
        }
        .nfa-trophy-ring--2 {
            width: 78%; height: 78%;
            border-color: oklch(0.8606 0.1731 91.9357 / .08);
            animation: trophyPulse 4s ease-in-out 0.6s infinite;
        }
        .nfa-trophy-ring--3 {
            width: 56%; height: 56%;
            border-color: oklch(0.8606 0.1731 91.9357 / .05);
            animation: trophyPulse 4s ease-in-out 1.2s infinite;
        }

        /* Glow backdrop behind trophy */
        .nfa-trophy-glow {
            position: absolute;
            width: 55%;
            height: 55%;
            border-radius: 50%;
            background: radial-gradient(circle, oklch(0.8606 0.1731 91.9357 / .1) 0%, transparent 70%);
            animation: glowBreath 3s ease-in-out infinite;
            pointer-events: none;
        }

        /* The trophy icon itself — floating */
        .nfa-trophy-icon {
            position: relative;
            z-index: 2;
            font-size: 5rem;
            color: var(--nfa-primary);
            opacity: .85;
            filter: drop-shadow(0 0 24px oklch(0.8606 0.1731 91.9357 / .35));
            animation: trophyFloat 5s ease-in-out infinite;
        }

        @@keyframes trophyFloat {
            0%, 100% { transform: translateY(0); }
            50%      { transform: translateY(-18px); }
        }
        @@keyframes trophyPulse {
            0%, 100% { transform: scale(1);   opacity: 1; }
            50%      { transform: scale(1.06); opacity: .5; }
        }
        @@keyframes glowBreath {
            0%, 100% { transform: scale(1);   opacity: 1; }
            50%      { transform: scale(1.15); opacity: .6; }
        }

        /* floating ambient shapes (subtle) */
        .nfa-float { position: absolute; border-radius: 50%; opacity: .04; pointer-events: none; z-index: 1; }
        .nfa-float-1 { width: 400px; height: 400px; background: var(--nfa-primary); top: -80px; right: -100px; animation: floatY 8s ease-in-out infinite; }
        .nfa-float-2 { width: 250px; height: 250px; background: oklch(0.62 0.18 250); bottom: 10%; left: -60px; animation: floatY 10s ease-in-out infinite reverse; }
        @@keyframes floatY { 0%,100%{ transform: translateY(0); } 50%{ transform: translateY(-30px); } }

        /* ─── Section Common ─── */
        .nfa-section { padding: 5rem 0; }
        .nfa-section-badge {
            display: inline-block;
            background: oklch(0.8606 0.1731 91.9357 / .12);
            color: var(--nfa-ring);
            font-size: .75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .08em;
            padding: .35rem 1rem;
            border-radius: 999px;
            margin-bottom: .75rem;
        }
        .nfa-heading {
            font-size: clamp(1.5rem, 3vw, 2.25rem);
            font-weight: 800;
            letter-spacing: -.01em;
            line-height: 1.2;
        }

        /* ─── Service Cards ─── */
        .nfa-service-card {
            background: var(--nfa-card);
            border: 1px solid var(--nfa-border);
            border-radius: calc(var(--nfa-radius) * 2);
            padding: 2rem 1.75rem;
            text-align: center;
            transition: transform .3s ease, box-shadow .3s ease, border-color .3s ease;
            height: 100%;
        }
        .nfa-service-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 16px 40px rgba(0,0,0,.08);
            border-color: var(--nfa-primary);
        }
        .nfa-service-icon {
            width: 72px; height: 72px;
            border-radius: 18px;
            display: inline-flex;
            align-items: center; justify-content: center;
            font-size: 1.75rem;
            margin-bottom: 1.25rem;
            transition: transform .3s;
        }
        .nfa-service-card:hover .nfa-service-icon { transform: scale(1.1) rotate(-3deg); }
        .si-fitness  { background: linear-gradient(135deg, oklch(0.8606 0.1731 91.9357 / .15), oklch(0.92 0.065 74 / .1)); color: oklch(0.7 0.15 90); }
        .si-cross    { background: linear-gradient(135deg, oklch(0.72 0.19 155 / .15), oklch(0.8 0.15 150 / .1)); color: oklch(0.55 0.17 155); }
        .si-box      { background: linear-gradient(135deg, oklch(0.6271 0.1936 33 / .15), oklch(0.72 0.15 30 / .1)); color: oklch(0.55 0.17 33); }
        .si-kick     { background: linear-gradient(135deg, oklch(0.62 0.18 250 / .15), oklch(0.72 0.14 245 / .1)); color: oklch(0.5 0.16 250); }

        /* ─── Contact Band ─── */
        .nfa-contact-band {
            background: linear-gradient(160deg, oklch(0.22 0.01 286), oklch(0.18 0.02 286));
            color: #fff;
            padding: 4rem 0;
        }
        .nfa-contact-item { display: flex; gap: .75rem; align-items: flex-start; margin-bottom: 1.25rem; }
        .nfa-contact-icon {
            width: 44px; height: 44px;
            border-radius: 12px;
            background: oklch(1 0 0 / .08);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
            color: var(--nfa-primary);
        }
        .nfa-contact-item .ci-label { font-size: .75rem; color: rgba(255,255,255,.5); text-transform: uppercase; letter-spacing: .05em; }
        .nfa-contact-item .ci-value { font-size: .9375rem; font-weight: 500; }

        .nfa-hour-row { display: flex; justify-content: space-between; padding: .5rem 0; border-bottom: 1px solid rgba(255,255,255,.08); font-size: .875rem; }
        .nfa-hour-row:last-child { border-bottom: none; }

        /* ─── Scroll reveal ─── */
        .nfa-reveal { opacity: 0; transform: translateY(24px); transition: opacity .6s ease, transform .6s ease; }
        .nfa-reveal.visible { opacity: 1; transform: translateY(0); }

        /* ─── Product Grid (Antigravity E-Commerce) ─── */
        .nfa-products-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.75rem;
        }

        @@media (max-width: 991.98px) {
            .nfa-products-grid { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
        }
        @@media (max-width: 575.98px) {
            .nfa-products-grid { grid-template-columns: 1fr; gap: 1rem; }
        }

        /* Card */
        .nfa-product-card {
            background: var(--nfa-card);
            border: 1px solid var(--nfa-border);
            border-radius: calc(var(--nfa-radius) * 2);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition:
                transform .45s cubic-bezier(.25,.46,.45,.94),
                box-shadow .45s cubic-bezier(.25,.46,.45,.94),
                border-color .35s ease;
            will-change: transform, box-shadow;
            cursor: pointer;
        }

        .nfa-product-card:hover {
            transform: translateY(-12px);
            box-shadow:
                0 20px 50px rgba(0, 0, 0, .08),
                0 0 0 1px oklch(0.8606 0.1731 91.9357 / .2),
                0 4px 30px oklch(0.8606 0.1731 91.9357 / .12);
            border-color: oklch(0.8606 0.1731 91.9357 / .35);
        }

        /* Image wrapper */
        .nfa-product-img-wrap {
            position: relative;
            aspect-ratio: 1 / 1;
            overflow: hidden;
            background: linear-gradient(135deg, var(--nfa-muted), oklch(0.96 0.005 90));
        }

        .nfa-product-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 1.25rem;
            transition: transform .5s cubic-bezier(.25,.46,.45,.94), filter .4s ease;
        }

        .nfa-product-card:hover .nfa-product-img-wrap img {
            transform: scale(1.08) translateY(-4px);
            filter: drop-shadow(0 8px 16px rgba(0,0,0,.1));
        }

        /* Subtle shimmer overlay on hover */
        .nfa-product-img-wrap::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(
                135deg,
                oklch(1 0 0 / 0) 40%,
                oklch(1 0 0 / .08) 50%,
                oklch(1 0 0 / 0) 60%
            );
            opacity: 0;
            transition: opacity .4s ease;
            pointer-events: none;
        }

        .nfa-product-card:hover .nfa-product-img-wrap::after {
            opacity: 1;
        }

        /* Info area */
        .nfa-product-info {
            padding: 1.25rem 1.5rem 1.5rem;
            display: flex;
            flex-direction: column;
            gap: .35rem;
            flex: 1;
        }

        .nfa-product-brand {
            font-size: .7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: var(--nfa-muted-fg);
            opacity: .75;
        }

        .nfa-product-name {
            font-size: 1rem;
            font-weight: 700;
            color: var(--nfa-fg);
            line-height: 1.35;
            margin: 0;
            letter-spacing: -.01em;
        }

        /* Subtle bottom accent line */
        .nfa-product-card::after {
            content: '';
            display: block;
            height: 3px;
            background: linear-gradient(90deg, var(--nfa-primary), oklch(0.92 0.065 74));
            transform: scaleX(0);
            transform-origin: left;
            transition: transform .4s cubic-bezier(.25,.46,.45,.94);
            border-radius: 0 0 calc(var(--nfa-radius) * 2) calc(var(--nfa-radius) * 2);
        }

        .nfa-product-card:hover::after {
            transform: scaleX(1);
        }

        /* Staggered reveal for product cards */
        .nfa-product-card.nfa-reveal { transition-delay: calc(var(--card-i, 0) * 80ms); }
    </style>
}

@* ═══════════════════════════════════════════
   PHASE 1 – HERO SECTION
   ═══════════════════════════════════════════ *@
<section class="nfa-hero" id="hero">
    @* Background image layer *@
    <div class="nfa-hero-bg" aria-hidden="true"></div>

    @* Ambient floating shapes *@
    <div class="nfa-float nfa-float-1"></div>
    <div class="nfa-float nfa-float-2"></div>

    <div class="container position-relative" style="z-index:3;">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <div class="nfa-section-badge" style="background:oklch(1 0 0 / .1);color:var(--nfa-primary);backdrop-filter:blur(8px);">
                    <i class="bi bi-lightning-charge-fill me-1"></i> NFA Spor Merkezi
                </div>
                <h1 class="nfa-hero-title mt-2 mb-4">
                    Gücünü Şekillendir,<br/>
                    <span class="nfa-gold">Sınırlarını Aş!</span>
                </h1>
                <p class="nfa-hero-sub mb-4">
                    Yaşam kalitesini arttırmanın en önemli hususlarından biri tartışmasız egzersizdir. Profesyonel eğitim programları ve ekipmanlarıyla, bireylere sağlıklı ve fit bir yaşamın kapılarını açar.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-nfa-primary px-4 py-2" style="font-size:.9375rem;">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="btn px-4 py-2"
                       style="border:1px solid rgba(255,255,255,.25);color:#fff;border-radius:var(--nfa-radius);font-weight:600;font-size:.9375rem;transition:background .2s,border-color .2s;backdrop-filter:blur(6px);background:rgba(255,255,255,.04);">
                        Kayıt Ol <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                </div>

                <div class="nfa-hero-stats">
                    <div><div class="hs-val">500+</div><div class="hs-lbl">Aktif Üye</div></div>
                    <div><div class="hs-val">15+</div><div class="hs-lbl">Eğitmen</div></div>
                    <div><div class="hs-val">10+</div><div class="hs-lbl">Yıl Tecrübe</div></div>
                </div>
            </div>

            @* Trophy Orb with animated rings *@
            <div class="col-lg-5 d-none d-lg-flex justify-content-center align-items-center">
                <div class="nfa-trophy-orb">
                    <div class="nfa-trophy-ring nfa-trophy-ring--1"></div>
                    <div class="nfa-trophy-ring nfa-trophy-ring--2"></div>
                    <div class="nfa-trophy-ring nfa-trophy-ring--3"></div>
                    <div class="nfa-trophy-glow"></div>
                    <i class="bi bi-trophy-fill nfa-trophy-icon"></i>
                </div>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════
   PHASE 2 – HAKKIMIZDA
   ═══════════════════════════════════════════ *@
<section class="nfa-section" id="about" style="background:var(--nfa-bg);">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5 nfa-reveal">
                <div style="aspect-ratio:4/3;border-radius:calc(var(--nfa-radius)*2);background:linear-gradient(135deg, var(--nfa-muted), var(--nfa-accent));display:flex;align-items:center;justify-content:center;border:1px solid var(--nfa-border);">
                    <i class="bi bi-heart-pulse-fill" style="font-size:4rem;color:var(--nfa-primary);opacity:.6;"></i>
                </div>
            </div>
            <div class="col-lg-7 nfa-reveal">
                <div class="nfa-section-badge">Hakkımızda</div>
                <h2 class="nfa-heading mb-3">Sadece Spor Değil,<br/><span style="color:var(--nfa-primary);">Bir Yaşam Felsefesi</span></h2>
                <p style="font-size:1rem;line-height:1.8;color:var(--nfa-muted-fg);">
                    Vücut geliştirme, sadece estetik bir görünüm elde etmek ya da kasları büyütmekten ibaret değildir; bu, zihinsel, fiziksel ve duygusal bir disiplin yolculuğudur.
                </p>
                <p style="font-size:1rem;line-height:1.8;color:var(--nfa-muted-fg);">
                    NFA Spor Merkezi'nde nitelikli antrenörler eşliğinde, kişiye özel programlarla sağlıklı bir dönüşüm hedefliyoruz. Modern ekipmanlarımız ve motivasyonla dolu ortamımız, her seviyeden sporcuyu karşılamak için hazır.
                </p>
                <div class="row g-3 mt-3">
                    <div class="col-6">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-check-circle-fill" style="color:oklch(0.65 0.19 155);"></i>
                            <span style="font-size:.875rem;font-weight:500;">Profesyonel Eğitmenler</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-check-circle-fill" style="color:oklch(0.65 0.19 155);"></i>
                            <span style="font-size:.875rem;font-weight:500;">Modern Ekipman</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-check-circle-fill" style="color:oklch(0.65 0.19 155);"></i>
                            <span style="font-size:.875rem;font-weight:500;">Kişisel Programlar</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-check-circle-fill" style="color:oklch(0.65 0.19 155);"></i>
                            <span style="font-size:.875rem;font-weight:500;">Motivasyonlu Ortam</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════
   PHASE 3 – HİZMETLER
   ═══════════════════════════════════════════ *@
<section class="nfa-section" id="services" style="background:var(--nfa-muted);">
    <div class="container">
        <div class="text-center mb-5 nfa-reveal">
            <div class="nfa-section-badge">Hizmetlerimiz</div>
            <h2 class="nfa-heading">Sana Uygun <span style="color:var(--nfa-primary);">Branşı</span> Keşfet</h2>
            <p class="text-nfa-muted mx-auto mt-2" style="max-width:520px;font-size:.9375rem;">
                Her seviyeye uygun programlarla hedeflerine ulaşmanı sağlıyoruz.
            </p>
        </div>

        <div class="row g-4">
            @* Fitness *@
            <div class="col-sm-6 col-lg-3 nfa-reveal">
                <div class="nfa-service-card">
                    <div class="nfa-service-icon si-fitness"><i class="bi bi-activity"></i></div>
                    <h5 style="font-weight:700;font-size:1.05rem;margin-bottom:.5rem;">Fitness</h5>
                    <p class="text-nfa-muted mb-0" style="font-size:.8375rem;line-height:1.6;">
                        Bireysel hedeflerine göre tasarlanmış antrenman programları ile formunu yakala.
                    </p>
                </div>
            </div>
            @* Cross Antrenman *@
            <div class="col-sm-6 col-lg-3 nfa-reveal">
                <div class="nfa-service-card">
                    <div class="nfa-service-icon si-cross"><i class="bi bi-lightning-charge"></i></div>
                    <h5 style="font-weight:700;font-size:1.05rem;margin-bottom:.5rem;">Cross Antrenman</h5>
                    <p class="text-nfa-muted mb-0" style="font-size:.8375rem;line-height:1.6;">
                        Fonksiyonel hareketlerle dayanıklılığını ve gücünü aynı anda geliştir.
                    </p>
                </div>
            </div>
            @* Boks *@
            <div class="col-sm-6 col-lg-3 nfa-reveal">
                <div class="nfa-service-card">
                    <div class="nfa-service-icon si-box"><i class="bi bi-fire"></i></div>
                    <h5 style="font-weight:700;font-size:1.05rem;margin-bottom:.5rem;">Boks</h5>
                    <p class="text-nfa-muted mb-0" style="font-size:.8375rem;line-height:1.6;">
                        Reflekslerini keskinleştir, özgüvenini ve kararlılığını zirveye taşı.
                    </p>
                </div>
            </div>
            @* Kick Box *@
            <div class="col-sm-6 col-lg-3 nfa-reveal">
                <div class="nfa-service-card">
                    <div class="nfa-service-icon si-kick"><i class="bi bi-bullseye"></i></div>
                    <h5 style="font-weight:700;font-size:1.05rem;margin-bottom:.5rem;">Kick Box</h5>
                    <p class="text-nfa-muted mb-0" style="font-size:.8375rem;line-height:1.6;">
                        Yüksek tempolu tekniklerle hem savunma hem kondisyon kazan.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════
   PHASE 3.5 – ÜRÜN LİSTELEME (Antigravity Grid)
   ═══════════════════════════════════════════ *@
<section class="nfa-section" id="products" style="background:var(--nfa-bg);">
    <div class="container">
        <div class="text-center mb-5 nfa-reveal">
            <div class="nfa-section-badge">E-Ticaret</div>
            <h2 class="nfa-heading">Takviye & <span style="color:var(--nfa-primary);">Supplement</span> Ürünleri</h2>
            <p class="text-nfa-muted mx-auto mt-2" style="max-width:520px;font-size:.9375rem;">
                Antrenman performansını zirveye taşıyacak, güvenilir HardLine Nutrition ürünleri.
            </p>
        </div>

